<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cardymccardface.photoimporter</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-c</string>
        <string>exec "$HOME/Library/Scripts/CardyMcCardface/photo_import.sh"</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartOnMount</key>
    <true/>

    <key>WatchPaths</key>
    <array>
        <string>/Volumes</string>
    </array>

    <key>ProcessType</key>
    <string>Background</string>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
